# Local persistent SQLite for development:
STUDYGENIE_USE_LOCAL_DB=1

# Hosted Postgres example:
# STUDYGENIE_USE_LOCAL_DB=0
# STUDYGENIE_DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

STUDYGENIE_SECRET_KEY=replace-this-with-a-long-random-secret
